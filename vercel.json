{
  "framework": "vite",
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains; preload"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:; connect-src 'self' https://*.supabase.co wss://*.supabase.co; frame-ancestors 'none'; object-src 'none'; base-uri 'self'; form-action 'self'; upgrade-insecure-requests"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=(), payment=(), usb=(), magnetometer=(), gyroscope=(), accelerometer=(), autoplay=(), fullscreen=(self)"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "X-Download-Options",
          "value": "noopen"
        },
        {
          "key": "X-Permitted-Cross-Domain-Policies",
          "value": "none"
        },
        {
          "key": "Cross-Origin-Opener-Policy",
          "value": "same-origin"
        },
        {
          "key": "Cross-Origin-Resource-Policy",
          "value": "same-origin"
        }
      ]
    }
  ],
  "rewrites": [
    { "source": "/.git/(.*)", "destination": "/__blocked__" },
    { "source": "/.git", "destination": "/__blocked__" },
    { "source": "/.env(.*)", "destination": "/__blocked__" },
    { "source": "/backup(.*)", "destination": "/__blocked__" },
    { "source": "/(.*)\\.bak", "destination": "/__blocked__" },
    { "source": "/(.*)\\.sql", "destination": "/__blocked__" },
    { "source": "/(.*)\\.dump", "destination": "/__blocked__" },
    { "source": "/(.*)\\.tar\\.gz", "destination": "/__blocked__" },
    { "source": "/(.*)\\.tgz", "destination": "/__blocked__" },
    { "source": "/(.*)\\.zip", "destination": "/__blocked__" },
    { "source": "/wp-admin(.*)", "destination": "/__blocked__" },
    { "source": "/wp-login(.*)", "destination": "/__blocked__" },
    { "source": "/wp-content(.*)", "destination": "/__blocked__" },
    { "source": "/wp-includes(.*)", "destination": "/__blocked__" },
    { "source": "/debug(.*)", "destination": "/__blocked__" },
    { "source": "/swagger(.*)", "destination": "/__blocked__" },
    { "source": "/openapi(.*)", "destination": "/__blocked__" },
    { "source": "/actuator(.*)", "destination": "/__blocked__" },
    { "source": "/_debugbar(.*)", "destination": "/__blocked__" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
